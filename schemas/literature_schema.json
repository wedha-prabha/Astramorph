{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["evidence", "gaps", "support_score"],
  "properties": {
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "gaps": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "support_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    }
  }
}
