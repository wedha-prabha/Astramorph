{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["summary", "steps", "targets", "confidence"],
  "properties": {
    "summary": { "type": "string" },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "confidence": { "type": "integer", "minimum": 0, "maximum": 100 }
  }
}
